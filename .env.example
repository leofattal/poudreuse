# Google OAuth client used by Supabase Auth (Poudreuse).
# Copy to .env.local and fill in — these are configured in the Supabase
# dashboard/Management API (server-side). The static browser client NEVER
# uses them; it only uses the publishable anon key hard-coded in js/cloud.js.
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
SUPABASE_PROJECT_REF=ikqwsxnczncfhsbmswaz
SUPABASE_URL=https://ikqwsxnczncfhsbmswaz.supabase.co
